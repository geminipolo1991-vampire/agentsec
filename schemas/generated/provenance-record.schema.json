{
  "$defs": {
    "TrustClass": {
      "enum": [
        "trusted-control",
        "authenticated-user",
        "internal-data",
        "external-untrusted",
        "suspected-adversarial",
        "unknown"
      ],
      "title": "TrustClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "confidentiality_labels": {
      "items": {
        "type": "string"
      },
      "title": "Confidentiality Labels",
      "type": "array",
      "uniqueItems": true
    },
    "content_digest": {
      "title": "Content Digest",
      "type": "string"
    },
    "first_seen_at": {
      "format": "date-time",
      "title": "First Seen At",
      "type": "string"
    },
    "integrity_labels": {
      "items": {
        "type": "string"
      },
      "title": "Integrity Labels",
      "type": "array",
      "uniqueItems": true
    },
    "parent_provenance_ids": {
      "items": {
        "type": "string"
      },
      "title": "Parent Provenance Ids",
      "type": "array"
    },
    "provenance_id": {
      "title": "Provenance Id",
      "type": "string"
    },
    "sanitizer_attestation_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sanitizer Attestation Id"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_id": {
      "title": "Source Id",
      "type": "string"
    },
    "source_type": {
      "title": "Source Type",
      "type": "string"
    },
    "tenant_id": {
      "title": "Tenant Id",
      "type": "string"
    },
    "transform_type": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Transform Type"
    },
    "trust_class": {
      "$ref": "#/$defs/TrustClass"
    }
  },
  "required": [
    "tenant_id",
    "source_type",
    "source_id",
    "trust_class",
    "content_digest"
  ],
  "title": "ProvenanceRecord",
  "type": "object"
}
